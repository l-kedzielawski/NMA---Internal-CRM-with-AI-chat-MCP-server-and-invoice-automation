# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# MySQL database connection settings
# Use values from your local Docker stack or managed database provider.
DB_HOST=${DB_HOST}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_NAME=${DB_NAME}
DB_PORT=${DB_PORT}

# CORS Configuration
# Frontend URL for CORS (comma-separated for multiple origins)
CORS_ORIGIN=${CORS_ORIGIN}

# Authentication
# IMPORTANT: Change this to a strong random string in production!
# Generate with: openssl rand -base64 32
# Or: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=${JWT_SECRET}

# Default admin password (used only on first run to create admin account)
# IMPORTANT: Set a strong password in production!
# Password must contain: 8+ chars, uppercase, lowercase, number, special char
DEFAULT_ADMIN_PASSWORD=${DEFAULT_ADMIN_PASSWORD}

# Rate limiting
# In development, limits are disabled unless ENABLE_DEV_RATE_LIMIT=true.
DISABLE_RATE_LIMIT=false
ENABLE_DEV_RATE_LIMIT=false

# Login limiter
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# General API limiter (per route scope and per user)
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=600

# Upload limiter
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000
UPLOAD_RATE_LIMIT_MAX=60

# AI / OpenRouter
OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
OPENROUTER_MODEL=${OPENROUTER_MODEL}
# Optional fallback model (used only when primary fails)
# OPENROUTER_FALLBACK_MODEL=openai/gpt-oss-20b:free
# Optional comma-separated model list. If set, overrides OPENROUTER_MODEL/FALLBACK.
# OPENROUTER_MODELS=google/gemma-2-9b-it:free,openai/gpt-oss-20b:free
OPENROUTER_TIMEOUT_MS=${OPENROUTER_TIMEOUT_MS}

# Internal call base for AI action execution (optional)
# AI_INTERNAL_API_BASE_URL=http://127.0.0.1:3001/api

# MCP service token controls
# If set, only this admin user ID can issue /api/auth/service-token
MCP_OWNER_USER_ID=${MCP_OWNER_USER_ID}
MCP_SERVICE_USERNAME=${MCP_SERVICE_USERNAME}
MCP_SERVICE_EMAIL=${MCP_SERVICE_EMAIL}
MCP_SERVICE_FULL_NAME=${MCP_SERVICE_FULL_NAME}
